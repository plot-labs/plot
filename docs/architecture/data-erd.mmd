        uuid accepted_by_user_id FK
        timestamptz expires_at
        timestamptz accepted_at
        timestamptz created_at
        timestamptz updated_at
    }

    SOURCE_REPOSITORIES {
        uuid id PK
        uuid workspace_id FK
        uuid connection_id FK
