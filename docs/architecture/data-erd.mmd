erDiagram
    USERS {
        uuid id PK
        citext email UK
        text display_name
        text avatar_url
        varchar status
        timestamptz last_login_at
        timestamptz created_at
        timestamptz updated_at
    }

    WORKSPACES {
        uuid id PK
        text name
        citext slug UK
        uuid created_by_user_id FK
        varchar status
        timestamptz created_at
        timestamptz updated_at
    }

    WORKSPACE_MEMBERS {
        uuid id PK
        uuid workspace_id FK
        uuid user_id FK
        varchar role
        varchar status
        timestamptz joined_at
        timestamptz created_at
        timestamptz updated_at
    }

    WORKSPACE_INVITATIONS {
        uuid id PK
        uuid workspace_id FK
