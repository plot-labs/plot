      "ordinal": 1,
      "outcome": "PASS",
      "metrics": { "latencyMs": 1234, "promptTokens": 10, "completionTokens": 20 },
      "codes": [],
      "attribution": {
        "requestedModel": "openai/gpt-5.4-nano",
        "servedModel": "openai/gpt-5.4-nano-2026-06-01",
        "observedUpstream": "openai",
        "responseIdHash": "sha256:6666666666666666666666666666666666666666666666666666666666666666"
      }
    }
  ]
}
