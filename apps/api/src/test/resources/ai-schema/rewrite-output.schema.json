{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["rewrites"],
  "properties": {
    "rewrites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["sentenceId", "body", "omit"],
        "properties": {
          "sentenceId": { "type": "string", "format": "uuid" },
          "body": { "type": ["string", "null"] },
          "omit": { "type": "boolean" }
        }
      }
    }
  }
}
