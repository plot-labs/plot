{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["sentences"],
  "properties": {
    "sentences": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["body"],
        "properties": { "body": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
