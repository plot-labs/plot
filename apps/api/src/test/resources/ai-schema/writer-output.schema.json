{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["sentences"],
  "properties": {
    "sentences": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["body", "intent", "conflictEvidenceIds"],
        "properties": {
          "body": { "type": "string", "minLength": 1 },
          "intent": { "type": "string", "enum": ["FACTUAL", "EDITORIAL", "UNRESOLVED_CONFLICT"] },
          "conflictEvidenceIds": { "type": "array", "items": { "type": "string", "format": "uuid" } }
        }
      }
    }
  }
}
