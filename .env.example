# Local runtime
SPRING_PROFILES_ACTIVE=dev
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
PLOT_API_BASE_URL=http://127.0.0.1:8080

# Next.js / Better Auth
# The API-managed Docker Compose service publishes PostgreSQL on a dynamic host
# port. Run `docker compose -f apps/api/compose.yaml port pgvector 5432` and
# replace 5432 below when necessary.
BETTER_AUTH_DATABASE_URL=postgres://plot:secret@127.0.0.1:5432/plot
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://127.0.0.1:3000

# GitHub OAuth App used only for Plot sign-in.
# Callback URL: http://127.0.0.1:3000/api/auth/callback/github
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
AUTH_ALLOWED_EMAILS=you@example.com

# Better Auth JWT issuer (read directly by the Next.js auth server).
PLOT_AUTH_JWT_ISSUER=https://app.useplot.xyz
PLOT_AUTH_JWT_AUDIENCE=plot-api

# Kotlin resource server.
# Spring Boot environment names remove dashes from canonical property names;
# for example, plot.auth.jwks-uri becomes PLOT_AUTH_JWKSURI.
PLOT_AUTH_ENABLED=true
PLOT_AUTH_REQUIRED=true
PLOT_AUTH_ISSUER=https://app.useplot.xyz
PLOT_AUTH_AUDIENCE=plot-api
PLOT_AUTH_JWKSURI=http://127.0.0.1:3000/api/auth/jwks

# GitHub App used for repository installation and import.
# Setup URL: http://127.0.0.1:3000/api/plot/github/installations/callback
# Required repository permissions: Metadata read-only, Pull requests read-only.
PLOT_GITHUB_ENABLED=false
PLOT_GITHUB_DEVONLY=true
PLOT_GITHUB_LOOPBACKONLY=true
PLOT_GITHUB_APPID=
PLOT_GITHUB_APPSLUG=
# Prefer exporting the PEM at runtime instead of storing it in .env:
# export PLOT_GITHUB_PRIVATEKEY="$(< /absolute/path/to/github-app.pem)"
PLOT_GITHUB_PRIVATEKEY=
# Generate with: openssl rand -hex 32
PLOT_GITHUB_STATESECRET=
PLOT_GITHUB_APIBASEURL=https://api.github.com
PLOT_GITHUB_WEBBASEURL=https://github.com
PLOT_GITHUB_STATETTLSECONDS=900
PLOT_GITHUB_IMPORTPAGECAP=20
PLOT_GITHUB_REPOSITORYPAGECAP=100

# OpenRouter-backed generation.
# Set both switches to true/openai only when a real provider key is available.
PLOT_AI_ENABLED=false
PLOT_AI_PROVIDER=openrouter
PLOT_AI_MODEL=openai/gpt-5.4-nano
PLOT_AI_BASEURL=https://openrouter.ai/api/v1
PLOT_AI_ROUTINGPROVIDER=openai
PLOT_AI_ALLOWFALLBACKS=false
PLOT_AI_REQUIREPARAMETERS=false
PLOT_AI_ZERODATARETENTION=false
PLOT_AI_CONTENTLOGGINGENABLED=false
PLOT_AI_TIMEOUT=45s
PLOT_AI_MAXOUTPUTTOKENS=4000
PLOT_AI_TRANSPORTRETRIES=1
PLOT_AI_SCHEMARETRIES=1
PLOT_AI_MAXMODELCALLS=12
PLOT_AI_MAXTOTALTOKENS=80000
PLOT_AI_MAXRUNDURATION=5m
PLOT_AI_CLAIMTIMEOUT=10m
PLOT_AI_RETRYINITIALDELAY=250ms
PLOT_AI_MAXEVIDENCECHARACTERS=120000
SPRING_AI_MODEL_CHAT=none
# For a live run, set SPRING_AI_MODEL_CHAT=openai and provide the OpenRouter key.
SPRING_AI_OPENAI_APIKEY=
SPRING_AI_OPENAI_MAXRETRIES=0
